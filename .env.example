# Anthropic (node consciousness / voice layer)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
NESTED_WORLDS_MODEL=claude-opus-4-7

# fal.ai — AI scene image generation (fal-ai/fast-sdxl)
FAL_KEY=your_fal_api_key_here

# Beta hardening — leave unset in dev. See README "Hosting for beta" section.
# Shared invite key. When set, every request needs ?key=... or X-Beta-Key header.
NESTED_WORLDS_BETA_KEY=
# Daily caps on paid external API calls (UTC). Counters live in SQLite.
NESTED_WORLDS_ANTHROPIC_DAILY_CALLS=500
NESTED_WORLDS_FAL_DAILY_CALLS=200
# Per-IP requests/min on /speak, /agent/voice, /image, /puzzle/attempt.
NESTED_WORLDS_RATE_LIMIT_PER_MIN=20
# Kill switches — set to "1" to disable.
NESTED_WORLDS_DISABLE_AI=
NESTED_WORLDS_DISABLE_IMAGES=
# Set to "1" only when behind a trusted reverse proxy that sets X-Forwarded-For.
NESTED_WORLDS_TRUST_PROXY=

# Sentry — optional. `sentry-sdk` is installed by default; set the DSN to
# enable error capture for unhandled request exceptions. Leave unset in dev.
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
