# Anthropic (node consciousness / voice layer)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
NESTED_WORLDS_MODEL=claude-opus-4-7

# fal.ai — AI scene image generation (fal-ai/fast-sdxl)
FAL_KEY=your_fal_api_key_here

# Beta hardening — leave unset in dev. See README "Hosting for beta" section.
# There is no shared invite key: the gate is the per-user `invite_keys` table.
# Mint per-user keys with `python main.py invite mint --name <player>`; minting
# the first one closes the gate so every request needs ?key=... or X-Beta-Key.
# Daily caps on paid external API calls (UTC). Counters live in SQLite.
NESTED_WORLDS_ANTHROPIC_DAILY_CALLS=500
NESTED_WORLDS_FAL_DAILY_CALLS=200
# Per-IP requests/min on /speak, /agent/voice, /image, /puzzle/attempt.
NESTED_WORLDS_RATE_LIMIT_PER_MIN=20
# Concurrent WebSocket connection caps (global, and per client IP).
NESTED_WORLDS_MAX_WS_CONNECTIONS=128
NESTED_WORLDS_MAX_WS_PER_IP=8
# Kill switches — set to "1" to disable.
NESTED_WORLDS_DISABLE_AI=
NESTED_WORLDS_DISABLE_IMAGES=
# Causal travel time: seconds between rings of a staged cascade (default 12).
NESTED_WORLDS_HOP_DELAY=
# Set to "0" to disable the pump thread that drains staged causal hops.
NESTED_WORLDS_CAUSAL_PUMP=
# Set to "1" only when behind a trusted reverse proxy. The limiter then reads
# the real client IP from a proxy-set header (see below) — never the
# client-spoofable left-most X-Forwarded-For.
NESTED_WORLDS_TRUST_PROXY=
# Trusted client-IP header used when TRUST_PROXY=1. Defaults to Fly-Client-IP
# (Fly overwrites it with the true client IP). Set to CF-Connecting-IP behind
# Cloudflare, etc. If absent at request time, the right-most X-Forwarded-For
# entry (the hop the trusted proxy appended) is used as a fallback.
NESTED_WORLDS_CLIENT_IP_HEADER=Fly-Client-IP

# Sentry — optional. `sentry-sdk` is installed by default; set the DSN to
# enable error capture for unhandled request exceptions. Leave unset in dev.
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
